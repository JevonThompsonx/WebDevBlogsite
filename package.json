{
  "name": "webdevblogsite",
  "version": "2.0.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": "22.x",
    "bun": "1.3.10"
  },
  "scripts": {
    "dev": "bun run db:migrate && next dev",
    "build": "bun run db:migrate && next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run drizzle/migrate.ts",
    "db:seed": "bun run drizzle/seed.ts"
  },
  "dependencies": {
    "@auth/core": "0.34.3",
    "@libsql/client": "0.17.0",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.45.1",
    "lucide-react": "0.577.0",
    "next": "16.1.6",
    "next-auth": "4.24.13",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "server-only": "0.0.1",
    "shiki": "4.0.1",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.9",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
